{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/((?!api/|src/|@vite|@react-refresh|node_modules/|icons/|favicon\\.svg).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/receipts/*.ts": {
      "maxDuration": 30
    },
    "api/**/*.ts": {
      "maxDuration": 10
    }
  }
}
