# Firebase Web app settings (safe for the browser; rules protect the data)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Supabase backend settings. Browser values are safe; service role stays server-only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel server-side secret. Store as one-line JSON; never prefix with VITE_.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Gemini server-side secret for receipt scanning. Never prefix with VITE_.
GEMINI_API_KEY=
