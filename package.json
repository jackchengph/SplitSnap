{
  "name": "splitsnap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:full": "set -a; [ ! -f .env.local ] || . ./.env.local; set +a; vercel dev --listen 5174",
    "build": "npm run typecheck && npm run typecheck:node && npm run typecheck:api && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest --exclude 'test/rules/**'",
    "test:run": "vitest run --exclude 'test/rules/**'",
    "test:rules": "firebase emulators:exec --project demo-splitsnap --only firestore 'vitest run test/rules/firestore.rules.test.ts'",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:api": "tsc -p tsconfig.api.json --noEmit",
    "verify": "npm run test:run && npm run test:rules && npm run build"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@supabase/supabase-js": "^2.110.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "heic-convert": "^2.1.0",
    "heic2any": "^0.0.4",
    "lucide-react": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.33.5",
    "tesseract.js": "^7.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "firebase-tools": "^15.22.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "jwks-rsa": {
      "jose": "4.15.9"
    }
  }
}
