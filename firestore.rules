rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validPublicProfile(profile, userId) {
      return profile.keys().hasOnly([
          'id',
          'displayName',
          'photoURL',
          'handle'
        ])
        && profile.id == userId
        && profile.displayName is string
        && (profile.photoURL == null || profile.photoURL is string)
        && profile.handle is string;
    }

    function validFriendship(friendship, friendshipId) {
      return friendship.keys().hasOnly([
          'memberKey',
          'memberIds',
          'requestedBy',
          'status',
          'blockedBy',
          'createdAt',
          'updatedAt'
        ])
        && friendship.memberKey == friendshipId
        && friendship.memberIds is list
        && friendship.memberIds.size() == 2
        && friendship.memberIds[0] is string
        && friendship.memberIds[1] is string
        && friendship.memberIds[0] < friendship.memberIds[1]
        && friendshipId == friendship.memberIds[0] + '__' + friendship.memberIds[1]
        && friendship.requestedBy in friendship.memberIds
        && friendship.status in [
          'pending',
          'connected',
          'declined',
          'removed',
          'blocked'
        ]
        && (
          friendship.blockedBy == null
          || friendship.blockedBy in friendship.memberIds
        )
        && friendship.createdAt is timestamp
        && friendship.updatedAt is timestamp;
    }

    function immutableFriendshipFields() {
      return request.resource.data.memberKey == resource.data.memberKey
        && request.resource.data.memberIds == resource.data.memberIds
        && request.resource.data.requestedBy == resource.data.requestedBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function pendingTransition() {
      return resource.data.status == 'pending'
        && request.auth.uid != resource.data.requestedBy
        && request.resource.data.status in ['connected', 'declined']
        && request.resource.data.blockedBy == null;
    }

    function connectedTransition() {
      return resource.data.status == 'connected'
        && (
          (
            request.resource.data.status == 'removed'
            && request.resource.data.blockedBy == null
          )
          || (
            request.resource.data.status == 'blocked'
            && request.resource.data.blockedBy == request.auth.uid
          )
        );
    }

    function blockedTransition() {
      return resource.data.status == 'blocked'
        && resource.data.blockedBy == request.auth.uid
        && request.resource.data.status == 'removed'
        && request.resource.data.blockedBy == null;
    }

    function renewedRequestTransition() {
      return resource.data.status in ['declined', 'removed']
        && request.auth.uid == resource.data.requestedBy
        && request.resource.data.status == 'pending'
        && request.resource.data.blockedBy == null;
    }

    function expenseMember(expense) {
      return signedIn() && request.auth.uid in expense.participantIds;
    }

    match /users/{userId} {
      allow get: if signedIn() && request.auth.uid == userId;
      allow list: if false;
      allow write: if false;

      match /devices/{deviceId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /publicProfiles/{userId} {
      allow get: if signedIn() && validPublicProfile(resource.data, userId);
      allow list, write: if false;
    }

    match /handles/{handle} {
      allow get: if signedIn()
        && resource.data.keys().hasOnly(['userId'])
        && resource.data.userId is string;
      allow list, write: if false;
    }

    match /friendCodes/{friendCode} {
      allow get: if signedIn()
        && resource.data.keys().hasOnly(['userId'])
        && resource.data.userId is string;
      allow list, write: if false;
    }

    match /restaurants/{restaurantId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.token.admin == true;
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn()
        && validFriendship(request.resource.data, friendshipId)
        && request.resource.data.status == 'pending'
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.blockedBy == null;
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberIds
        && validFriendship(request.resource.data, friendshipId)
        && immutableFriendshipFields()
        && request.resource.data.updatedAt > resource.data.updatedAt
        && (
          pendingTransition()
          || connectedTransition()
          || blockedTransition()
          || renewedRequestTransition()
        );
      allow delete: if false;
    }

    match /expenses/{expenseId} {
      allow read: if expenseMember(resource.data);
      allow create: if signedIn()
        && request.resource.data.payerId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if signedIn()
        && resource.data.payerId == request.auth.uid
        && request.resource.data.payerId == resource.data.payerId;
      allow delete: if signedIn() && resource.data.payerId == request.auth.uid;

      match /paymentProofs/{participantId} {
        allow read: if expenseMember(
          get(/databases/$(database)/documents/expenses/$(expenseId)).data
        );
        allow create, update: if signedIn() && request.auth.uid == participantId;
        allow delete: if false;
      }
    }
  }
}
